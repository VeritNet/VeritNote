{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x64-debug-dev",
      "displayName": "x64 Debug Dev",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CLOSURE_OPTIMIZATION": "OFF"
      }
    },
    {
      "name": "x64-release-dev",
      "displayName": "x64 Release Dev",
      "inherits": "x64-debug-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CLOSURE_OPTIMIZATION": "OFF"
      }
    },
    {
      "name": "x86-debug-dev",
      "displayName": "x86 Debug Dev",
      "inherits": "windows-base",
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CLOSURE_OPTIMIZATION": "OFF"
      }
    },
    {
      "name": "x86-release-dev",
      "displayName": "x86 Release Dev",
      "inherits": "x86-debug-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CLOSURE_OPTIMIZATION": "OFF"
      }
    },
    {
      "name": "x64-debug-closure",
      "displayName": "x64 Debug Closure",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CLOSURE_OPTIMIZATION": "ON"
      }
    },
    {
      "name": "x64-release-closure",
      "displayName": "x64 Release Closure",
      "inherits": "x64-debug-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CLOSURE_OPTIMIZATION": "ON"
      }
    },
    {
      "name": "x86-debug-closure",
      "displayName": "x86 Debug Closure",
      "inherits": "windows-base",
      "architecture": {
        "value": "x86",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CLOSURE_OPTIMIZATION": "ON"
      }
    },
    {
      "name": "x86-release-closure",
      "displayName": "x86 Release Closure",
      "inherits": "x86-debug-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CLOSURE_OPTIMIZATION": "ON"
      }
    }
  ]
}
